<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Нижняя тень -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#9C6A17" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Основной объёмный градиент -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFE9A0"
                android:centerColor="#F3C24F"
                android:endColor="#D79A27"
                android:angle="0" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#FFF3C6" />
        </shape>
    </item>

    <!-- Мягкий верхний блик -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#70FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Лёгкая внутренняя подсветка слева -->
    <item android:left="3dp" android:top="3dp" android:right="26dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#35FFF8C8"
                android:endColor="#00FFF8C8"
                android:angle="0" />
            <corners android:radius="18dp" />
        </shape>
    </item>

</layer-list>