<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Нижняя опорная подложка -->
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="#163A63"/>
        </shape>
    </item>

    <!-- Основная поверхность -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#6AAEFF"
                android:centerColor="#3F84D8"
                android:endColor="#245FA5"/>
            <stroke
                android:width="1dp"
                android:color="#88DCEBFF"/>
        </shape>
    </item>

    <!-- Внутренний верхний блик -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#52FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

    <!-- Очень мягкое внутреннее нижнее затемнение -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="26dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:endColor="#18000000"/>
        </shape>
    </item>

</layer-list>