<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="#163E6B"/>
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#4A90E2"
                android:centerColor="#2B6CB0"
                android:endColor="#1E4E85"/>
            <stroke
                android:width="1dp"
                android:color="#88D6E8FF"/>
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#55FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>