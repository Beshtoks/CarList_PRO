<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="#1E5C3D"/>
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#48BB78"
                android:centerColor="#2F855A"
                android:endColor="#256746"/>
            <stroke
                android:width="1dp"
                android:color="#66E2FFE9"/>
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#44FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>