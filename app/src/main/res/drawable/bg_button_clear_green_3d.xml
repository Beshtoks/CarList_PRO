<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="0"
                android:startColor="#082112"
                android:centerColor="#0E3B21"
                android:endColor="#146834"/>
            <stroke
                android:width="1.6dp"
                android:color="#61F4A3"/>
        </shape>
    </item>

    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp"/>
            <stroke
                android:width="1dp"
                android:color="#1FFFFFFF"/>
        </shape>
    </item>

    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp"/>
            <gradient
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="34dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:endColor="#22000000"/>
        </shape>
    </item>

</layer-list>