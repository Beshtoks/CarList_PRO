<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFC7F2"
                android:centerColor="#FF91E7"
                android:endColor="#E06FC9" />
            <stroke
                android:width="1dp"
                android:color="#B85AA4" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#34FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="32dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:endColor="#16000000" />
        </shape>
    </item>

</layer-list>