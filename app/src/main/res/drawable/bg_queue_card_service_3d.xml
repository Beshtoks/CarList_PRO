<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="0"
                android:startColor="#9F2B67"
                android:endColor="#FFA7D6" />
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <gradient
                android:angle="0"
                android:startColor="#B73779"
                android:centerColor="#FF74B9"
                android:centerX="0.62"
                android:endColor="#FFC6E7" />
            <stroke
                android:width="1dp"
                android:color="#FFFFA9DB" />
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <gradient
                android:angle="0"
                android:startColor="#C84486"
                android:centerColor="#FF8DC8"
                android:centerX="0.58"
                android:endColor="#FFD6EE" />
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:angle="270"
                android:startColor="#55FFD9F1"
                android:centerColor="#22FFF6FB"
                android:centerY="0.34"
                android:endColor="#00FFF6FB" />
        </shape>
    </item>

</layer-list>