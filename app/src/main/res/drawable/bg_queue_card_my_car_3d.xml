<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <gradient
                android:angle="0"
                android:startColor="#5A2E00"
                android:endColor="#F0BE3F"/>
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp"/>
            <gradient
                android:angle="0"
                android:startColor="#6A3900"
                android:centerColor="#FFD96A"
                android:centerX="0.69"
                android:endColor="#FFF09C"/>
            <stroke
                android:width="1dp"
                android:color="#FFD96A"/>
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/>
            <gradient
                android:angle="0"
                android:startColor="#7A4300"
                android:centerColor="#F3C95A"
                android:centerX="0.64"
                android:endColor="#FFF4B8"/>
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
            <gradient
                android:angle="270"
                android:startColor="#66FFF7C8"
                android:centerColor="#30FFFDE8"
                android:centerY="0.34"
                android:endColor="#00FFFDE8"/>
        </shape>
    </item>

</layer-list>