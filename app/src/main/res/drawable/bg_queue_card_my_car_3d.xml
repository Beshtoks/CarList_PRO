<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="0"
                android:startColor="#352206"
                android:centerColor="#594117"
                android:endColor="#E2A93B" />
            <stroke
                android:width="1dp"
                android:color="#FFD46C" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="25dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#22FFF3CB"
                android:endColor="#00FFF3CB" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <stroke
                android:width="1dp"
                android:color="#40FFE08A" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="30dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:endColor="#28000000" />
        </shape>
    </item>

</layer-list>