<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#D7EEFA"
                android:centerColor="#AED6F1"
                android:endColor="#7FB9DB" />
            <stroke
                android:width="1dp"
                android:color="#679CBC" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#58FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:right="1dp"
        android:top="30dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:endColor="#22000000" />
        </shape>
    </item>

</layer-list>