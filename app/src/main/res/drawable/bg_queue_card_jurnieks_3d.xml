<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="0"
                android:startColor="#1A6FC8"
                android:endColor="#97D7FF" />
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <gradient
                android:angle="0"
                android:startColor="#2E84DE"
                android:centerColor="#58AEFF"
                android:centerX="0.60"
                android:endColor="#BDE8FF" />
            <stroke
                android:width="1dp"
                android:color="#FFAEDFFF" />
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <gradient
                android:angle="0"
                android:startColor="#4094EC"
                android:centerColor="#74BEFF"
                android:centerX="0.58"
                android:endColor="#D3F0FF" />
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:angle="270"
                android:startColor="#55DDF4FF"
                android:centerColor="#22F6FCFF"
                android:centerY="0.34"
                android:endColor="#00F6FCFF" />
        </shape>
    </item>

</layer-list>