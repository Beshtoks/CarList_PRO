<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="#7F1D1D"/>
        </shape>
    </item>

    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#E35D5D"
                android:centerColor="#C53030"
                android:endColor="#962222"/>
            <stroke
                android:width="1dp"
                android:color="#66FFD6D6"/>
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="270"
                android:startColor="#44FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>