<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#0B0E1C"
                android:endColor="#151025" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#AA8B39D6" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <stroke
                android:width="1dp"
                android:color="#5529D0FF" />
            <gradient
                android:angle="0"
                android:startColor="#0A0D19"
                android:centerColor="#101226"
                android:endColor="#140E22" />
        </shape>
    </item>

</layer-list>