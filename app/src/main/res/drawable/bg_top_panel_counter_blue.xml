<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient
                android:angle="0"
                android:startColor="#080F18"
                android:centerColor="#0A1220"
                android:endColor="#09111B"/>
            <stroke
                android:width="1.6dp"
                android:color="#4DBFFF"/>
        </shape>
    </item>

    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp"/>
            <stroke
                android:width="1dp"
                android:color="#24FFFFFF"/>
        </shape>
    </item>

    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp"/>
            <gradient
                android:angle="270"
                android:startColor="#12FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>