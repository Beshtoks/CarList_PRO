<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <gradient
                android:angle="0"
                android:startColor="#4A2600"
                android:endColor="#DFAF36"/>
        </shape>
    </item>

    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp"/>
            <gradient
                android:angle="0"
                android:startColor="#5A3000"
                android:centerColor="#F0C864"
                android:centerX="0.68"
                android:endColor="#FFE48A"/>
            <stroke
                android:width="1dp"
                android:color="#F2C768"/>
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/>
            <gradient
                android:angle="0"
                android:startColor="#6A3A00"
                android:centerColor="#E9BD56"
                android:centerX="0.64"
                android:endColor="#FFEFA6"/>
        </shape>
    </item>

    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
            <gradient
                android:angle="270"
                android:startColor="#55FFF6C5"
                android:centerColor="#22FFFCE0"
                android:centerY="0.35"
                android:endColor="#00FFFCE0"/>
        </shape>
    </item>

</layer-list>