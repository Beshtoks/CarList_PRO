<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Единый нижний 3D-слой на всю ширину карточки -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#E6BC8E" />
        </shape>
    </item>

    <!-- Основная верхняя поверхность карточки -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <gradient
                android:angle="0"
                android:startColor="#F2D1B5"
                android:endColor="#F2D1B5" />
        </shape>
    </item>

    <!-- Мягкий верхний блик для сохранения объёма -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="5dp"
                android:topRightRadius="5dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:angle="270"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>