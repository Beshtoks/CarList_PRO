<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="58dp"
    android:orientation="vertical"
    android:background="@drawable/bg_registry_row_neon"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:inputType="number"
            android:textColor="#D6F6FF"
            android:textSize="22sp"
            android:textColorHint="#6F8FB8"
            android:hint="" />

        <TextView
            android:id="@+id/tvLetters"
            android:layout_width="110dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="-"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#BFEFFF"
            android:background="@drawable/bg_registry_category_blue" />
    </LinearLayout>

    <View
        android:id="@+id/underline"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="2dp"
        android:background="#2A6EDB" />

</LinearLayout>