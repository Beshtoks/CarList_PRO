<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:foreground="@android:color/transparent"
    app:cardCornerRadius="6dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#55000000"
    app:useCompatPadding="false">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/cardSurface"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_queue_card_standard_3d" />

        <View
            android:id="@+id/leftPanel"
            android:layout_width="74dp"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="1dp"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="1dp" />

        <View
            android:id="@+id/diagonalDivider"
            android:layout_width="2dp"
            android:layout_height="38dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="72dp"
            android:rotation="-29" />

        <TextView
            android:id="@+id/positionText"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="1"
            android:textColor="#FF090500"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/numberText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="74dp"
            android:layout_marginEnd="50dp"
            android:gravity="center"
            android:text="245"
            android:textColor="#FFFFFFFF"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/categoryLetterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:text=""
            android:textColor="#FFD8D8D8"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/statusSmallText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="58dp"
            android:gravity="center"
            android:text=""
            android:textColor="#FFFFE8FA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>