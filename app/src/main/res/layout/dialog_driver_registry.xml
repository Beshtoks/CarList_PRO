<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_dialog_registry_neon">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TECHNICAL MENU"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#AEE8FF"
        android:gravity="center" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Allowed driver numbers"
        android:textSize="14sp"
        android:textColor="#7EB8FF"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/registryRecycler"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:overScrollMode="never"
        android:scrollbars="vertical" />

    <Button
        android:id="@+id/btnOk"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="DONE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#BFEFFF"
        android:background="@drawable/bg_registry_done_neon" />

</LinearLayout>