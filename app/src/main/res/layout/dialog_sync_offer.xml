<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_sync_offer_card"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <ImageView
        android:id="@+id/ivSyncIcon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@drawable/ic_sync_offer_cloud"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SYNC OFFER"
        android:textStyle="bold"
        android:textSize="22sp"
        android:letterSpacing="0.06"
        android:textColor="#CDA7FF"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="List uploaded"
        android:textSize="14sp"
        android:textColor="#BFC6DA"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:id="@+id/chipBy"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_sync_offer_chip"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvByLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BY"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#E6E8F2"/>

        <TextView
            android:id="@+id/tvByValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="#99"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#D985FF"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/minutesPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_sync_offer_minutes_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvMinutesValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="497"
            android:textStyle="bold"
            android:textSize="58sp"
            android:textColor="#DB9CFF"/>

        <TextView
            android:id="@+id/tvMinutesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MINUTES AGO"
            android:textStyle="bold"
            android:textSize="15sp"
            android:letterSpacing="0.05"
            android:textColor="#D7B3FF"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Download the list?"
        android:textSize="13sp"
        android:textColor="#BFC6DA"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvSecondsLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15 sec"
        android:textSize="13sp"
        android:textColor="#95B4D6"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNo"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="NO"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_sync_offer_btn_no"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="DOWNLOAD"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_sync_offer_btn_yes"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>

</LinearLayout>