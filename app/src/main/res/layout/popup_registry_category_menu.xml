<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_registry_popup_neon"
    android:padding="6dp">

    <TextView
        android:id="@+id/actionMyCar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="MY CAR"
        android:textColor="#FFD86B"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/actionVan"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="VAN"
        android:textColor="#7ED3FF"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/actionBus"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="BUS"
        android:textColor="#7ED3FF"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/actionClear"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="CLEAR"
        android:textColor="#C8D3E0"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

</LinearLayout>