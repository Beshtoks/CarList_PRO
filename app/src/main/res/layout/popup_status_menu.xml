<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="190dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_status_popup"
    android:padding="6dp">

    <TextView
        android:id="@+id/actionStandard"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="NO STATUS"
        android:textColor="#FFD0D0"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/actionService"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="SERVICE"
        android:textColor="#FF67D8"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/actionOffice"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="OFFICE"
        android:textColor="#FF67D8"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/actionJurnieks"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="JURNIEKS"
        android:textColor="#4DB7FF"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />
</LinearLayout>